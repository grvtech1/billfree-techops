# ── BillFree TechOps web — environment template ──────────────────────────────
# Copy to `.env` (or `.env.local`) and fill in. NEVER commit the real .env.

# Which backend the build targets:
#   gateway  → the microservices API gateway (JWT/REST). The showcase default.
#   gas      → the legacy Google Apps Script backend (or mock when VITE_GAS_URL is empty).
VITE_BACKEND=gateway

# Gateway base URL. Empty → relative paths (the web container's nginx proxies
# /api and /auth to the gateway). For `npm run dev`, point at the gateway origin:
#   VITE_GATEWAY_URL=http://localhost:8080
VITE_GATEWAY_URL=

# Legacy GAS backend URL (only used when VITE_BACKEND=gas). Empty → mock data.
VITE_GAS_URL=
