# ── Dependencies ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ──────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ── Environment & secrets (NEVER commit) ──────────────────────
# The production GAS deployment URL and any keys live only in local
# .env files and CI secrets. Only .env.example is tracked.
.env
.env.*
!.env.example

# ── Google Apps Script / clasp ────────────────────────────────
# .clasp.json contains the live scriptId — keep it local; commit the
# .clasp.json.example template instead.
apps/gas/.clasp.json
.clasprc.json

# ── Test / coverage ───────────────────────────────────────────
coverage/
.vitest/

# ── Editor / OS ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.log
npm-debug.log*

# ── Local archives ────────────────────────────────────────────
apps/web/_archive/

# ── Terraform (state + plans + generated key + kubeconfig — NEVER commit) ──
# Plan files can embed sensitive resource values (keys, tokens) and are
# environment-specific binary artifacts, not source.
infra/terraform/.terraform/
infra/terraform/.terraform.lock.hcl
infra/terraform/*.tfstate
infra/terraform/*.tfstate.*
infra/*.tfstate
infra/*.tfstate.*
infra/terraform/terraform.tfvars
infra/terraform/.ssh/
infra/terraform/*.pem
infra/terraform/kubeconfig
tfplan
*.tfplan
**/tfplan
**/*.plan
crash.log

# ── Editor backups ────────────────────────────────────────────
*~
*.swp
*.bak

# Playwright visual-regression (local, env-specific)
apps/web/e2e/__snapshots__/
apps/web/test-results/
apps/web/playwright-report/
