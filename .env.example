# ─────────────────────────────────────────────────────────────────────────────
# Local docker-compose secrets. Copy to `.env` (git-ignored) and fill in.
#   cp .env.example .env
# The compose file falls back to throwaway dev defaults if these are unset, so
# the stack boots with zero config — but set real values for anything shared.
# ─────────────────────────────────────────────────────────────────────────────

# Signing secret for internal JWTs (min 16 chars). Generate: openssl rand -hex 24
JWT_SECRET=

# Shared key for the WhatsApp/portal intake routes. Generate: openssl rand -hex 24
INTAKE_API_KEY=

# Postgres password (used by the postgres container and every service's DATABASE_URL).
POSTGRES_PASSWORD=

# SPA origin allowed by the gateway's CORS (comma-separated for multiple).
CORS_ORIGINS=http://localhost:3000

# Set to "false" to bypass Google OAuth locally (log in by email). Production
# leaves this unset, which ENFORCES Google verification.
REQUIRE_GOOGLE_AUTH=false

# ── report-service (optional; monthly report email + AI narrative) ────────────
GEMINI_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=reports@billfree.in
ADMIN_EMAILS=admin@billfree.in,manager@billfree.in
