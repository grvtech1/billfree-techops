# Copy to terraform.tfvars and adjust. Lock down the CIDRs for anything real.
region                      = "ap-south-1"
project                     = "billfree-techops"
environment                 = "dev"
control_plane_instance_type = "t3.medium"
worker_instance_type        = "t3.large"
worker_count                = 2
kubernetes_version          = "1.30"

# SECURITY: restrict these to your own IP. Find it with: curl -s ifconfig.me
# Leaving them at 0.0.0.0/0 exposes SSH (22) and the Kubernetes API (6443) to the
# whole internet — the terraform validation blocks reject that value.
ssh_allowed_cidr = "203.0.113.4/32"  # ← replace with YOUR.IP/32
api_allowed_cidr = "203.0.113.4/32"  # ← replace with YOUR.IP/32
