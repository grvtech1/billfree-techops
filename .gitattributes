# Normalize line endings — store everything as LF in the repo regardless of OS.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.svg text eol=lf
*.ico binary

# GitHub Linguist overrides — exclude legacy GAS monolith and generated files
# from language stats so TypeScript shows as the primary language.
apps/gas/** linguist-vendored=true
apps/web/dist/** linguist-vendored=true
deploy/charts/**/*.yaml linguist-language=YAML
